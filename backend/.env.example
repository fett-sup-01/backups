# Copie para .env e ajuste. NUNCA comite o .env com chaves reais.
DATABASE_URL=postgresql+psycopg2://backup:backup@db:5432/backup

# Chave PUBLICA age de recuperacao (doc 5.3). A PRIVADA correspondente mora no
# 1Password e NUNCA toca o servidor. Todo segredo e cifrado tambem para ela, para
# que a ferramenta offline consiga socorrer uma maquina de cliente que morreu.
# Obrigatoria: o backend se recusa a cifrar sem ela (fail-closed).
RECOVERY_AGE_PUBKEY=age1skeghjpfdsavpd0uamw63089gdjn2catl2g0ss09arna7pmhvadqjc0d49

# Chave PUBLICA minisign, so para entregar/exibir ao agente (verificacao de update).
# A privada de assinatura tambem mora no 1Password.
MINISIGN_PUBLIC_KEY=

# Minutos de validade do token de enrollment efemero.
ENROLLMENT_TTL_MIN=60
