# PRODUCAO — copie para .env na VPS e preencha com segredos FORTES.
# Gere segredos assim:
#   JWT_SECRET:      openssl rand -hex 32
#   ADMIN_PASSWORD:  openssl rand -base64 18
#   POSTGRES_PASSWORD: openssl rand -base64 24

APP_ENV=prod

# Banco (o compose usa estes p/ o container do Postgres E monta o DATABASE_URL abaixo)
POSTGRES_USER=backup
POSTGRES_PASSWORD=TROQUE-senha-forte-do-postgres
POSTGRES_DB=backup
DATABASE_URL=postgresql+psycopg2://backup:TROQUE-senha-forte-do-postgres@db:5432/backup

# Auth do dashboard (a validacao recusa subir se estiver fraco/padrao)
JWT_SECRET=TROQUE-por-32+-chars-aleatorios
ADMIN_LOGIN=admin
ADMIN_PASSWORD=TROQUE-senha-forte-min-12

# Cripto (doc 5). PUBLICAS aqui; as privadas correspondentes moram no 1Password.
RECOVERY_AGE_PUBKEY=age1...          # obrigatoria (fail-closed)
MINISIGN_PUBLIC_KEY=RWQ...           # entregue ao agente p/ verificar updates

ENROLLMENT_TTL_MIN=60

# Dominio do dashboard (TLS). Usado pelo nginx (envsubst) e pelo certbot.
DOMAIN=dashboard.suaempresa.com.br

# CORS: vazio (mesma origem via nginx). So preencha se servir o front de outra origem.
CORS_ORIGINS=

# /docs fica OFF automaticamente em prod.
DOCS_ENABLED=false

# ==== BACKUP DO BACKEND (doc 13) ====
# Par age DEDICADO de backup (NAO reutilize a chave de recuperacao de clientes).
#   Gere: age-keygen -o backup.key   (guarde a PRIVADA no 1Password; use no restore)
#   Cole aqui so a PUBLICA (age1...). Vazio = dump sem cifra (nao recomendado).
BACKUP_AGE_RECIPIENT=age1...
# Destino OFFSITE (o dump nao pode morrer com a VPS). Configure backup/rclone.conf.
RCLONE_REMOTE=b2:meu-bucket/frota-backend
# Quantos dumps manter (local e remoto, em dias/quantidade).
RETENTION_KEEP=14
# Intervalo entre dumps (segundos). 86400 = 1x/dia.
BACKUP_INTERVAL_SEC=86400
